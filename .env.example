# AI-One — Environment Variables
# ================================
# Copy this file to backend/.env and fill in your real values.
# NEVER commit your actual .env file to version control.

# IBM watsonx.ai credentials
# Obtain from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key_here

# Your watsonx.ai project ID
# Find it in: IBM Cloud → watsonx.ai → Manage → General → Project ID
IBM_PROJECT_ID=your_project_id_here

# Deployment region for your watsonx.ai instance
# Common values: us-south, eu-gb, eu-de, jp-tok, au-syd
IBM_REGION=us-south
